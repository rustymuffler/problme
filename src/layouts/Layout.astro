---
/**
 * Base layout for all pages. Provides the sticky translucent header,
 * footer, global styles, and OG/SEO meta tags.
 */
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const { title, description = 'Building in public. One problem at a time.', ogImage = '/assets/og/og-default.svg' } = Astro.props;

const pathname = new URL(Astro.request.url).pathname;
const isHome  = pathname === '/' || pathname === '';
const isBlog  = pathname.startsWith('/blog');
const isAbout = pathname.startsWith('/about');

const siteUrl = 'https://probl.me';
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="generator" content={Astro.generator} />

  <title>{title}</title>
  <meta name="description" content={description} />

  <!-- Open Graph -->
  <meta property="og:type"        content="website" />
  <meta property="og:title"       content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image"       content={`${siteUrl}${ogImage}`} />
  <meta property="og:url"         content={`${siteUrl}${pathname}`} />

  <!-- Twitter / X -->
  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:title"       content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image"       content={`${siteUrl}${ogImage}`} />

  <!-- Fonts: Bunny Fonts (privacy-friendly, GDPR, no IP logging) — loaded async to avoid render-blocking -->
  <link rel="preconnect" href="https://fonts.bunny.net" crossorigin />
  <link rel="preload" href="https://fonts.bunny.net/css?family=hanken-grotesk:400,500,600,700,800|jetbrains-mono:400,500,600,700&display=swap" as="style" onload="this.onload=null;this.rel='stylesheet'" />
  <noscript><link href="https://fonts.bunny.net/css?family=hanken-grotesk:400,500,600,700,800|jetbrains-mono:400,500,600,700&display=swap" rel="stylesheet" /></noscript>

  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>

<body>

  <!-- ─── HEADER ─────────────────────────────────────────────────────── -->
  <header style="position:sticky; top:0; z-index:50; background:rgba(21,18,14,0.85); backdrop-filter:blur(12px); -webkit-backdrop-filter:blur(12px); border-bottom:1px solid var(--color-border);">
    <div style="max-width:var(--max-width); margin:0 auto; padding:16px 32px; display:flex; align-items:center; justify-content:space-between;">

      <!-- Logo -->
      <a href="/" style="display:flex; align-items:center; font-family:var(--font-mono); font-size:20px; font-weight:600; color:var(--color-text-primary); letter-spacing:-0.01em;">
        <span style="color:var(--color-amber); margin-right:8px;">&gt;</span>probl<span style="color:var(--color-terracotta);">.me</span><span class="cursor" style="display:inline-block; width:8px; height:17px; background:var(--color-amber); margin-left:5px; border-radius:1px; animation:blink 1.1s steps(1) infinite;" aria-hidden="true"></span>
      </a>

      <!-- Nav -->
      <nav aria-label="Main navigation" style="display:flex; align-items:center; gap:8px; font-family:var(--font-mono); font-size:13px;">
        <a class="navlink" href="/"      style={`color:${isHome  ? 'var(--color-amber)' : 'var(--color-text-secondary)'}; padding:10px 14px;`}>home</a>
        <a class="navlink" href="/blog"  style={`color:${isBlog  ? 'var(--color-amber)' : 'var(--color-text-secondary)'}; padding:10px 14px;`}>blog</a>
        <a class="navlink" href="/about" style={`color:${isAbout ? 'var(--color-amber)' : 'var(--color-text-secondary)'}; padding:10px 14px;`}>about</a>
        <a class="navlink" href="https://github.com/rustymuffler" target="_blank" rel="noopener noreferrer"
           style="color:var(--color-text-secondary); padding:10px 14px; border:1px solid var(--color-border-strong); border-radius:8px; margin-left:6px;">github &#8599;</a>
      </nav>

    </div>
  </header>

  <!-- ─── PAGE CONTENT ────────────────────────────────────────────────── -->
  <main>
    <slot />
  </main>

  <!-- ─── FOOTER ─────────────────────────────────────────────────────── -->
  <footer style="border-top:1px solid var(--color-border); margin-top:56px;">
    <div style="max-width:var(--max-width); margin:0 auto; padding:40px 32px; display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:20px;">

      <!-- Logo + tagline -->
      <div>
        <div style="display:flex; align-items:center; font-family:var(--font-mono); font-size:16px; font-weight:600;">
          <span style="color:var(--color-amber); margin-right:8px;">&gt;</span>probl<span style="color:var(--color-terracotta);">.me</span><span class="cursor" style="display:inline-block; width:7px; height:14px; background:var(--color-amber); margin-left:4px; border-radius:1px; animation:blink 1.1s steps(1) infinite;" aria-hidden="true"></span>
        </div>
        <div style="font-family:var(--font-mono); font-size:12px; color:var(--color-text-muted); margin-top:8px;">Building in public. One problem at a time.</div>
      </div>

      <!-- Footer nav -->
      <div style="display:flex; gap:22px; font-family:var(--font-mono); font-size:12px;">
        <a class="navlink" href="/blog"  style="color:var(--color-text-secondary);">blog</a>
        <a class="navlink" href="/about" style="color:var(--color-text-secondary);">about</a>
        <a class="navlink" href="https://github.com/rustymuffler" target="_blank" rel="noopener noreferrer" style="color:var(--color-text-secondary);">github</a>
        <span style="color:var(--color-text-muted);">&copy; 2026</span>
      </div>

    </div>
  </footer>

</body>
</html>
