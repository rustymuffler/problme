---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = 'Building in public. One problem at a time.',
  ogImage = '/assets/og/og-default.svg',
} = Astro.props;

const pathname = new URL(Astro.request.url).pathname;
const isHome  = pathname === '/' || pathname === '';
const isBlog  = pathname.startsWith('/blog');
const isAbout = pathname.startsWith('/about');

const siteUrl = 'https://probl.me';
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="generator" content={Astro.generator} />

  <title>{title}</title>
  <meta name="description" content={description} />

  <!-- Open Graph -->
  <meta property="og:type"        content="website" />
  <meta property="og:title"       content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image"       content={`${siteUrl}${ogImage}`} />
  <meta property="og:url"         content={`${siteUrl}${pathname}`} />

  <!-- Twitter / X -->
  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:title"       content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image"       content={`${siteUrl}${ogImage}`} />

  <!-- Fonts: Bunny Fonts (privacy-friendly, no IP logging) -->
  <link rel="preconnect" href="https://fonts.bunny.net" crossorigin />
  <link
    rel="preload"
    href="https://fonts.bunny.net/css?family=hanken-grotesk:400,500,600,700,800|jetbrains-mono:400,500,600,700&display=swap"
    as="style"
    onload="this.onload=null;this.rel='stylesheet'"
  />
  <noscript>
    <link
      href="https://fonts.bunny.net/css?family=hanken-grotesk:400,500,600,700,800|jetbrains-mono:400,500,600,700&display=swap"
      rel="stylesheet"
    />
  </noscript>

  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- No-JS fallback: keep desktop nav visible on mobile so navigation still works -->
  <noscript>
    <style>
      @media (max-width: 639px) {
        .desktop-nav { display: flex !important; flex-wrap: wrap; gap: 4px !important; }
        .hamburger   { display: none !important; }
      }
    </style>
  </noscript>
</head>

<body>

  <!-- ─── HEADER ───────────────────────────────────────────────────────── -->
  <header class="site-header">
    <div class="header-inner">

      <!-- Logo: "> probl.me▌" -->
      <a href="/" class="site-logo" aria-label="probl.me — home">
        <span class="lp" aria-hidden="true">&gt;</span>probl<span class="ldm">.me</span><span class="cursor" aria-hidden="true"></span>
      </a>

      <!-- Desktop / tablet inline nav (hidden at ≤639px by CSS + JS) -->
      <nav class="desktop-nav" aria-label="Main navigation">
        <a class={`dn-link${isHome  ? ' dn-active' : ''}`} href="/">home</a>
        <a class={`dn-link${isBlog  ? ' dn-active' : ''}`} href="/blog">blog</a>
        <a class={`dn-link${isAbout ? ' dn-active' : ''}`} href="/about">about</a>
        <a
          class="dn-link dn-gh"
          href="https://github.com/rustymuffler"
          target="_blank"
          rel="noopener noreferrer"
        >github &#8599;</a>
      </nav>

      <!-- Hamburger toggle — shown only at ≤639px (RESPONSIVE-SPEC.md §2.2) -->
      <button
        id="hamburger"
        class="hamburger"
        type="button"
        aria-expanded="false"
        aria-controls="mobile-nav"
        aria-label="Open menu"
      >
        <span class="bar" aria-hidden="true"></span>
        <span class="bar" aria-hidden="true"></span>
        <span class="bar" aria-hidden="true"></span>
      </button>

    </div>

    <!-- Mobile nav dropdown panel (full-width, anchored below header-inner row) -->
    <nav id="mobile-nav" class="mobile-nav" aria-label="Mobile navigation" hidden>
      <a class={`mn-link${isHome  ? ' mn-active' : ''}`} href="/">home</a>
      <a class={`mn-link${isBlog  ? ' mn-active' : ''}`} href="/blog">blog</a>
      <a class={`mn-link${isAbout ? ' mn-active' : ''}`} href="/about">about</a>
      <a
        class="mn-link"
        href="https://github.com/rustymuffler"
        target="_blank"
        rel="noopener noreferrer"
      >github &#8599;</a>
    </nav>
  </header>

  <!-- ─── PAGE CONTENT ─────────────────────────────────────────────────── -->
  <main>
    <slot />
  </main>

  <!-- ─── FOOTER ───────────────────────────────────────────────────────── -->
  <footer class="site-footer">
    <div class="footer-inner">

      <!-- Brand block -->
      <div class="footer-brand">
        <div class="footer-logo">
          <span class="lp" aria-hidden="true">&gt;</span>probl<span class="ldm">.me</span><span class="cursor cursor-sm" aria-hidden="true"></span>
        </div>
        <div class="footer-tag">Building in public. One problem at a time.</div>
      </div>

      <!-- Footer nav — credits link lives here only, never in the top nav -->
      <nav class="footer-nav" aria-label="Footer navigation">
        <a class="fn-link" href="/blog">blog</a>
        <a class="fn-link" href="/about">about</a>
        <a class="fn-link" href="https://github.com/rustymuffler" target="_blank" rel="noopener noreferrer">github</a>
        <a class="fn-link" href="/credits">credits</a>
        <span class="fn-copy">&copy; 2026</span>
      </nav>

    </div>
  </footer>

</body>
</html>

<style>
/* ─── Header ──────────────────────────────────────────────────────────── */
.site-header {
  position: sticky;
  top: 0;
  z-index: 50;
  background: rgba(21, 18, 14, 0.85);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border-bottom: 1px solid var(--color-border);
}

.header-inner {
  max-width: var(--max-width);
  margin: 0 auto;
  padding: 16px var(--gutter);
  display: flex;
  align-items: center;
  justify-content: space-between;
}

/* ── Logo ─────────────────────────────────────────────────────────────── */
.site-logo {
  display: inline-flex;
  align-items: center;
  font-family: var(--font-mono);
  font-size: 20px;
  font-weight: 600;
  color: var(--color-text-primary);
  letter-spacing: -0.01em;
  text-decoration: none;
  min-height: 44px;
}

.lp  { color: var(--color-amber);      margin-right: 8px; }
.ldm { color: var(--color-terracotta); }

/* Blinking cursor — gated via .cursor global class in global.css reduced-motion rule */
.cursor {
  display: inline-block;
  width: 8px;
  height: 17px;
  background: var(--color-amber);
  margin-left: 5px;
  border-radius: 1px;
  animation: blink 1.1s steps(1) infinite;
}

.cursor-sm {
  width: 7px;
  height: 14px;
  margin-left: 4px;
}

/* ── Desktop / tablet nav ─────────────────────────────────────────────── */
.desktop-nav {
  display: flex;
  align-items: center;
  gap: 4px;
  font-family: var(--font-mono);
  font-size: 13px;
}

.dn-link {
  color: var(--color-text-secondary);
  padding: 10px 14px;
  min-height: 44px;
  display: inline-flex;
  align-items: center;
  text-decoration: none;
  transition: color var(--duration-fast);
}

.dn-link:hover { color: var(--color-text-primary); }
.dn-active     { color: var(--color-amber); }
.dn-active:hover { color: var(--color-amber); }

.dn-gh {
  border: 1px solid var(--color-border-strong);
  border-radius: 8px;
  margin-left: 6px;
  transition: color var(--duration-fast), border-color var(--duration-fast);
}

.dn-gh:hover { border-color: var(--color-amber); }

/* ── Hamburger button (44×44px, shown only at ≤639px) ────────────────── */
.hamburger {
  display: none;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  gap: 5px;
  width: 44px;
  height: 44px;
  padding: 0;
  background: transparent;
  border: 1px solid var(--color-border-strong);
  border-radius: 8px;
  cursor: pointer;
}

.bar {
  display: block;
  width: 18px;
  height: 2px;
  background: var(--color-text-secondary);
  border-radius: 1px;
  transition: background var(--duration-fast);
}

.hamburger:hover .bar,
.hamburger[aria-expanded="true"] .bar {
  background: var(--color-text-primary);
}

/* ── Mobile nav panel (RESPONSIVE-SPEC.md §2.2) ──────────────────────── */
.mobile-nav {
  background: var(--color-surface);
  border-top: 1px solid var(--color-border);
}

.mobile-nav[hidden] {
  display: none !important;
}

.mn-link {
  display: block;
  font-family: var(--font-mono);
  font-size: 14px;
  color: var(--color-text-secondary);
  padding: 15px 20px;
  border-bottom: 1px solid var(--color-border);
  text-decoration: none;
  transition: background var(--duration-fast), color var(--duration-fast);
}

.mn-link:last-child {
  border-bottom: none;
}

.mn-link:hover {
  background: var(--color-surface-alt);
  color: var(--color-text-primary);
}

.mn-active {
  color: var(--color-amber);
  background: var(--color-surface-alt);
}

.mn-active:hover {
  color: var(--color-amber);
}

/* ─── Footer ──────────────────────────────────────────────────────────── */
.site-footer {
  border-top: 1px solid var(--color-border);
  margin-top: 56px;
}

.footer-inner {
  max-width: var(--max-width);
  margin: 0 auto;
  padding: 40px var(--gutter);
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 20px;
}

.footer-logo {
  display: inline-flex;
  align-items: center;
  font-family: var(--font-mono);
  font-size: 16px;
  font-weight: 600;
}

.footer-tag {
  font-family: var(--font-mono);
  font-size: 12px;
  color: var(--color-text-muted);
  margin-top: 8px;
}

.footer-nav {
  display: flex;
  align-items: center;
  gap: 22px;
  font-family: var(--font-mono);
  font-size: 12px;
  flex-wrap: wrap;
}

.fn-link {
  color: var(--color-text-secondary);
  text-decoration: none;
  min-height: 44px;
  display: inline-flex;
  align-items: center;
  transition: color var(--duration-fast);
}

.fn-link:hover { color: var(--color-text-primary); }

.fn-copy { color: var(--color-text-muted); }

/* ─── Responsive ──────────────────────────────────────────────────────── */
@media (max-width: 639px) {
  .header-inner {
    padding-inline: 20px;
  }

  /* Hide desktop nav; show hamburger */
  .desktop-nav { display: none; }
  .hamburger   { display: flex; }

  /* Stack footer vertically */
  .footer-inner {
    flex-direction: column;
    align-items: flex-start;
  }
}
</style>

<script>
  const hamburger = document.getElementById('hamburger') as HTMLButtonElement | null;
  const mobileNav = document.getElementById('mobile-nav') as HTMLElement | null;

  if (hamburger && mobileNav) {
    const open = () => {
      hamburger.setAttribute('aria-expanded', 'true');
      hamburger.setAttribute('aria-label', 'Close menu');
      mobileNav.removeAttribute('hidden');
    };

    const close = () => {
      hamburger.setAttribute('aria-expanded', 'false');
      hamburger.setAttribute('aria-label', 'Open menu');
      mobileNav.setAttribute('hidden', '');
    };

    hamburger.addEventListener('click', () => {
      hamburger.getAttribute('aria-expanded') === 'true' ? close() : open();
    });

    // Close when any mobile nav link is tapped
    mobileNav.querySelectorAll('a').forEach((a) => a.addEventListener('click', close));

    // Close on Escape, return focus to trigger
    document.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Escape' && hamburger.getAttribute('aria-expanded') === 'true') {
        close();
        hamburger.focus();
      }
    });
  }
</script>
