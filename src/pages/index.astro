---
import Layout from '../layouts/Layout.astro';
---

<Layout title="probl.me — Building in public. One problem at a time." description="I'm Richard — a cybersecurity and SaaS product manager building personal projects with AI. This is where I share what works, what breaks, and what I'd tell someone starting from zero.">

  <section style="max-width:var(--max-width); margin:0 auto; padding:120px 32px; text-align:center;">
    <div style="font-family:var(--font-mono); font-size:12px; color:var(--color-text-muted); letter-spacing:0.14em; text-transform:uppercase; margin-bottom:24px;">// coming soon</div>
    <h1 style="font-size:56px; font-weight:800; line-height:1.05; letter-spacing:-0.025em; margin:0 0 24px;">Building in public.<br>One <span style="color:var(--color-amber);">problem</span> at a time.</h1>
    <p style="font-size:18px; line-height:1.75; color:var(--color-text-secondary); max-width:34em; margin:0 auto;">
      The site is under construction. The foundation is live.
    </p>
  </section>

</Layout>
