---
import Layout from '../../../layouts/Layout.astro';
import ArticleCard from '../../../components/ArticleCard.astro';
import type { Category } from '../../../components/CategoryPill.astro';
import { getCollection } from 'astro:content';

// Pre-render one static page per known tag
export async function getStaticPaths() {
  const allPosts = await getCollection('posts');

  // Seed with known icon-strip tags + collect any from posts
  const seed = ['pm-craft', 'ai-development', 'tech-tools', 'astro', 'github',
                 'security', 'building-in-public', 'celly'];
  const fromPosts = allPosts.flatMap(p => [p.data.category, ...p.data.tags]);
  const all = [...new Set([...seed, ...fromPosts])];

  return all.map(tag => ({ params: { tag } }));
}

const { tag } = Astro.params;

const allPosts = (await getCollection('posts'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const filtered = allPosts.filter(p =>
  p.data.category === tag || p.data.tags.includes(tag)
);

const fmt = new Intl.DateTimeFormat('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
---

<Layout
  title={`Tagged ${tag} — probl.me`}
  description={`All posts tagged ${tag} on probl.me.`}
>

  <!-- ─── PAGE HEAD ─────────────────────────────────────────────────────── -->
  <section class="page-head">
    <div class="eyebrow">// the blog</div>
    <h1 class="page-h1">Tagged <span class="accent">{tag}</span></h1>
    <p class="page-sub mono">
      {filtered.length} {filtered.length === 1 ? 'post' : 'posts'}
      &nbsp;&middot;&nbsp;
      <a class="clear-link" href="/blog">clear filter &times;</a>
    </p>

    <!-- Filter pills — active state determined at build time -->
    <div class="pills" role="list">
      <a class="pill"                                             href="/blog"                    role="listitem">all</a>
      <a class={`pill${tag === 'pm-craft'       ? ' is-active--amber' : ''}`} href="/blog/tag/pm-craft"       role="listitem">pm-craft</a>
      <a class={`pill${tag === 'ai-development' ? ' is-active--terra' : ''}`} href="/blog/tag/ai-development" role="listitem">ai-development</a>
      <a class={`pill${tag === 'tech-tools'     ? ' is-active--olive' : ''}`} href="/blog/tag/tech-tools"     role="listitem">tech-tools</a>
    </div>
  </section>

  <!-- ─── RESULTS GRID ─────────────────────────────────────────────────── -->
  <section class="grid-wrap">
    {filtered.length > 0 ? (
      <div class="card-grid">
        {filtered.map((post) => (
          <ArticleCard
            href={`/blog/${post.id.replace(/\.(md|mdx)$/, '')}`}
            heroImage={post.data.heroImage ?? '/assets/og/og-default.svg'}
            heroAlt={post.data.title}
            category={post.data.category as Category}
            title={post.data.title}
            excerpt={post.data.description}
            date={fmt.format(post.data.date)}
            readTime={post.data.readTime}
          />
        ))}
      </div>
    ) : (
      <div class="empty-state">
        <div class="empty-label">
          no posts tagged <span class="accent">{tag}</span> yet
        </div>
        <p class="empty-body">
          This topic is on the roadmap. Check back soon, or browse everything.
        </p>
        <a class="browse-all" href="/blog">browse all posts</a>
      </div>
    )}
  </section>

</Layout>

<style>
/* ── Page head ────────────────────────────────────────────── */
.page-head {
  max-width: var(--max-width);
  margin: 0 auto;
  padding: 64px 32px 32px;
}

.eyebrow {
  font-family: var(--font-mono);
  font-size: 12px;
  color: var(--color-text-muted);
  letter-spacing: 0.14em;
  text-transform: uppercase;
}

.page-h1 {
  font-size: 40px;
  font-weight: 800;
  letter-spacing: -0.02em;
  margin: 14px 0 0;
}

.accent {
  color: var(--color-amber);
}

.page-sub {
  font-size: 18px;
  color: var(--color-text-secondary);
  line-height: 1.7;
  margin: 16px 0 0;
}

.mono {
  font-family: var(--font-mono);
  font-size: 14px;
}

.clear-link {
  color: var(--color-amber);
  transition: opacity 0.15s;
}

.clear-link:hover { opacity: 0.8; }

.pills {
  display: flex;
  gap: 10px;
  margin-top: 32px;
  flex-wrap: wrap;
}

.pill {
  font-family: var(--font-mono);
  font-size: 13px;
  border-radius: var(--radius-pill);
  padding: 8px 16px;
  min-height: 44px;
  display: inline-flex;
  align-items: center;
  color: var(--color-text-secondary);
  background: transparent;
  border: 1px solid var(--color-border);
  transition: filter 0.2s;
}

.pill:hover { filter: brightness(1.15); }

.is-active--amber { background: #F2A24B; color: #15120E; border-color: #F2A24B; font-weight: 600; }
.is-active--terra { background: #E8674A; color: #15120E; border-color: #E8674A; font-weight: 600; }
.is-active--olive { background: #9DB066; color: #15120E; border-color: #9DB066; font-weight: 600; }

/* ── Grid ─────────────────────────────────────────────────── */
.grid-wrap {
  max-width: var(--max-width);
  margin: 0 auto;
  padding: 8px 32px 40px;
}

.card-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 22px;
}

/* ── Empty state ──────────────────────────────────────────── */
.empty-state {
  border: 1px dashed var(--color-border-strong);
  border-radius: var(--radius-2xl);
  padding: 56px 32px;
  text-align: center;
  margin-top: 4px;
}

.empty-label {
  font-family: var(--font-mono);
  font-size: 13px;
  color: var(--color-text-muted);
}

.empty-body {
  font-size: 15px;
  color: var(--color-text-secondary);
  margin: 12px 0 0;
}

.browse-all {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  margin-top: 20px;
  font-family: var(--font-mono);
  font-size: 13px;
  color: var(--color-text-secondary);
  border: 1px solid var(--color-border-strong);
  border-radius: var(--radius-lg);
  padding: 11px 22px;
  min-height: 44px;
  transition: border-color 0.2s, color 0.2s;
}

.browse-all:hover {
  border-color: var(--color-amber);
  color: var(--color-text-primary);
}

/* ── Responsive ───────────────────────────────────────────── */
@media (max-width: 1023px) {
  .card-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (max-width: 639px) {
  .page-head {
    padding: 48px 20px 28px;
  }

  .page-h1 {
    font-size: 30px;
  }

  .grid-wrap {
    padding: 8px 20px 32px;
  }

  .card-grid {
    grid-template-columns: 1fr;
  }
}
</style>
