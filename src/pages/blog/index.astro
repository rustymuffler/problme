---
import Layout from '../../layouts/Layout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import CategoryPill from '../../components/CategoryPill.astro';
import { getCollection } from 'astro:content';
import type { Category } from '../../components/CategoryPill.astro';

const allPosts = (await getCollection('posts'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const fmt = new Intl.DateTimeFormat('en-US', { year: 'numeric', month: 'short', day: 'numeric' });

const featuredPost = allPosts[0] ?? null;
---

<Layout
  title="Blog — probl.me"
  description="Two posts a week on product craft, building with AI, and the stack that runs this site. Honest about what worked and what didn't."
>

  <!-- ─── PAGE HEAD ─────────────────────────────────────────────────────── -->
  <section class="page-head">
    <div class="eyebrow">// the blog</div>
    <h1 class="page-h1">Notes from building in public</h1>
    <p class="page-sub">
      Two posts a week on product craft, building with AI, and the stack that
      runs this site. Honest about what worked and what didn't.
    </p>

    <!-- Filter pills — "all" is active; others link to pre-rendered tag pages -->
    <div class="pills" role="list">
      <a class="pill is-active--amber" href="/blog"                    role="listitem">all</a>
      <a class="pill"                  href="/blog/tag/pm-craft"       role="listitem">pm-craft</a>
      <a class="pill"                  href="/blog/tag/ai-development" role="listitem">ai-development</a>
      <a class="pill"                  href="/blog/tag/tech-tools"     role="listitem">tech-tools</a>
    </div>
  </section>

  <!-- ─── FEATURED POST ────────────────────────────────────────────────── -->
  {featuredPost && (
    <section class="feat-wrap">
      <a
        class="feat-card"
        href={`/blog/${featuredPost.id.replace(/\.(md|mdx)$/, '')}`}
      >
        <img
          src={featuredPost.data.heroImage ?? '/assets/og/og-default.svg'}
          alt={featuredPost.data.title}
          class="feat-img"
        />
        <div class="feat-body">
          <div class="feat-meta-row">
            <CategoryPill category={featuredPost.data.category as Category} />
            <span class="feat-label">featured</span>
          </div>
          <h2 class="feat-title">{featuredPost.data.title}</h2>
          <p class="feat-desc">{featuredPost.data.description}</p>
          <div class="feat-date">
            {fmt.format(featuredPost.data.date)} &middot; {featuredPost.data.readTime} read
          </div>
        </div>
      </a>
    </section>
  )}

  <!-- ─── GRID ─────────────────────────────────────────────────────────── -->
  <section class="grid-wrap">
    {allPosts.length > 1 ? (
      <div class="card-grid">
        {allPosts.slice(1).map((post) => {
          const slug = post.id.replace(/\.(md|mdx)$/, '');
          return (
            <ArticleCard
              href={`/blog/${slug}`}
              heroImage={post.data.heroImage ?? '/assets/og/og-default.svg'}
              heroAlt={post.data.title}
              category={post.data.category as Category}
              title={post.data.title}
              excerpt={post.data.description}
              date={fmt.format(post.data.date)}
              readTime={post.data.readTime}
            />
          );
        })}
      </div>
    ) : allPosts.length === 0 ? (
      <div class="empty-state">
        <div class="empty-label">// no posts yet</div>
        <p class="empty-body">
          The first articles are in the pipeline. Check back soon.
        </p>
      </div>
    ) : null}
  </section>

</Layout>

<style>
/* ── Page head ────────────────────────────────────────────── */
.page-head {
  max-width: var(--max-width);
  margin: 0 auto;
  padding: 64px 32px 32px;
}

.eyebrow {
  font-family: var(--font-mono);
  font-size: 12px;
  color: var(--color-text-muted);
  letter-spacing: 0.14em;
  text-transform: uppercase;
}

.page-h1 {
  font-size: 40px;
  font-weight: 800;
  letter-spacing: -0.02em;
  margin: 14px 0 0;
}

.page-sub {
  font-size: 18px;
  color: var(--color-text-secondary);
  line-height: 1.7;
  max-width: 40em;
  margin: 16px 0 0;
}

.pills {
  display: flex;
  gap: 10px;
  margin-top: 32px;
  flex-wrap: wrap;
}

.pill {
  font-family: var(--font-mono);
  font-size: 13px;
  border-radius: var(--radius-pill);
  padding: 8px 16px;
  min-height: 44px;
  display: inline-flex;
  align-items: center;
  color: var(--color-text-secondary);
  background: transparent;
  border: 1px solid var(--color-border);
  transition: filter 0.2s;
}

.pill:hover { filter: brightness(1.15); }

/* Active pill variants */
.is-active--amber { background: #F2A24B; color: #15120E; border-color: #F2A24B; font-weight: 600; }
.is-active--terra { background: #E8674A; color: #15120E; border-color: #E8674A; font-weight: 600; }
.is-active--olive { background: #9DB066; color: #15120E; border-color: #9DB066; font-weight: 600; }

/* ── Featured card ────────────────────────────────────────── */
.feat-wrap {
  max-width: var(--max-width);
  margin: 0 auto;
  padding: 8px 32px 0;
}

.feat-card {
  display: grid;
  grid-template-columns: 1.1fr 1fr;
  background: var(--color-surface);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-2xl);
  overflow: hidden;
  transition: border-color 0.25s, box-shadow 0.25s;
}

.feat-card:hover {
  border-color: var(--color-amber);
  box-shadow: 0 10px 30px rgba(0, 0, 0, 0.4);
}

.feat-card:hover .feat-title {
  color: #fff;
}

.feat-img {
  display: block;
  width: 100%;
  height: 100%;
  min-height: 280px;
  object-fit: cover;
}

.feat-body {
  padding: 40px;
}

.feat-meta-row {
  display: flex;
  gap: 10px;
  align-items: center;
}

.feat-label {
  font-family: var(--font-mono);
  font-size: 11px;
  color: var(--color-text-muted);
  letter-spacing: 0.1em;
  text-transform: uppercase;
}

.feat-title {
  font-size: 30px;
  font-weight: 800;
  letter-spacing: -0.02em;
  line-height: 1.12;
  margin: 18px 0 0;
  color: var(--color-text-primary);
  transition: color 0.25s;
}

.feat-desc {
  font-size: 16px;
  color: var(--color-text-secondary);
  line-height: 1.65;
  margin: 14px 0 0;
}

.feat-date {
  font-family: var(--font-mono);
  font-size: 12px;
  color: var(--color-text-muted);
  margin-top: 24px;
}

/* ── Grid ─────────────────────────────────────────────────── */
.grid-wrap {
  max-width: var(--max-width);
  margin: 0 auto;
  padding: 36px 32px 40px;
}

.card-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 22px;
}

/* ── Empty state ──────────────────────────────────────────── */
.empty-state {
  border: 1px dashed var(--color-border-strong);
  border-radius: var(--radius-2xl);
  padding: 56px 32px;
  text-align: center;
  margin-top: 4px;
}

.empty-label {
  font-family: var(--font-mono);
  font-size: 13px;
  color: var(--color-text-muted);
}

.empty-body {
  font-size: 15px;
  color: var(--color-text-secondary);
  margin: 12px 0 0;
}

/* ── Responsive ───────────────────────────────────────────── */
@media (max-width: 1023px) {
  /* Featured card stacks: image on top, text below */
  .feat-card {
    grid-template-columns: 1fr;
  }

  .feat-img {
    height: 300px;
    min-height: unset;
  }

  .card-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (max-width: 639px) {
  .page-head {
    padding: 48px 20px 28px;
  }

  .page-h1 {
    font-size: 30px;
  }

  .feat-wrap {
    padding: 8px 20px 0;
  }

  .feat-img {
    height: 220px;
  }

  .feat-body {
    padding: 24px 20px;
  }

  .feat-title {
    font-size: 22px;
  }

  .grid-wrap {
    padding: 28px 20px 32px;
  }

  .card-grid {
    grid-template-columns: 1fr;
  }
}
</style>
